{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "crons": [
        {
            "path": "/api/keepalive",
            "schedule": "0 12 * * *"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}